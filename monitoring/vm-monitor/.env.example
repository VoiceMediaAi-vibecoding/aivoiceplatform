# Copy this file to .env on the monitoring VM and fill in real values.
# NEVER commit .env — add it to .gitignore.

# Grafana admin password. CHANGE after first login.
# Use a 20+ char random string from a password manager.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING

# The URL Grafana uses to refer to itself in links and OAuth callbacks.
# If you use Tailscale MagicDNS (default), the hostname is your VM's hostname.
GF_SERVER_ROOT_URL=http://monitoring-vm:3000
